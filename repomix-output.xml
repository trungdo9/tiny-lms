  front: string;
  back: string;
  hint?: string;
  isFlipped: boolean;
  onFlip: () => void;
}
```

### CSS Flip Animation
```css
.card-container {
  perspective: 1000px;
}

.card-inner {
  transition: transform 0.6s;
  transform-style: preserve-3d;
}

.card-inner.flipped {
  transform: rotateY(180deg);
}

.card-front, .card-back {
  backface-visibility: hidden;
}

.card-back {
  transform: rotateY(180deg);
}
```

