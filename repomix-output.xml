import { IsString, IsOptional, IsBoolean, MaxLength } from 'class-validator';

export class CreateThemeDto {
  @IsString() @MaxLength(100)
  name: string;

  @IsString() @IsOptional() @MaxLength(200)
  description?: string;

  @IsString() @IsOptional() primaryColor?: string;
  @IsString() @IsOptional() secondaryColor?: string;
  @IsString() @IsOptional() accentColor?: string;
  @IsString() @IsOptional() backgroundColor?: string;
  @IsString() @IsOptional() textColor?: string;
  @IsString() @IsOptional() primaryForeground?: string;
  @IsString() @IsOptional() borderColor?: string;
  @IsString() @IsOptional() logoUrl?: string;
  @IsString() @IsOptional() faviconUrl?: string;
  @IsString() @IsOptional() customCss?: string;
  @IsString() @IsOptional() fontFamily?: string;
}

export class UpdateThemeDto extends CreateThemeDto {
  // All fields optional via inheritance
}
```

### 2. Create Service (`themes.service.ts`)

Key methods:
- `findAll()` -- return all themes ordered by `createdAt desc`
- `findActive()` -- `findFirst({ where: { isActive: true } })`
- `findOne(id)` -- find by ID, throw `NotFoundException` if missing
- `create(dto)` -- generate slug from name, create theme
- `update(id, dto)` -- update fields, regenerate slug if name changed
- `activate(id)` -- **transaction**: `updateMany({ isActive: false })` then `update({ id, isActive: true })`
- `remove(id)` -- check not active, then delete

```typescript
async activate(id: string) {
  return this.prisma.$transaction(async (tx) => {
    // Deactivate all
    await tx.theme.updateMany({
      where: { isActive: true },
      data: { isActive: false },
    });
    // Activate target
    return tx.theme.update({
      where: { id },
      data: { isActive: true },
    });
  });
}
```

### 3. Create Controller (`themes.controller.ts`)

```typescript
@Controller('themes')
export class ThemesController {
  // GET /themes/active (public -- no guard)
  // GET /themes (admin -- SupabaseAuthGuard)
