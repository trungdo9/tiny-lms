  @Put('reorder')
  reorder(
    @Request() req: any,
    @Param('lessonId') lessonId: string,
    @Body() body: ReorderActivitiesDto,
  ) {
    return this.service.reorder(req.user.id, lessonId, body.activityIds);
  }
