                              ) : (
                                <Lock className="w-5 h-5 text-gray-400" />
                              )}
                            </div>
                          </div>
                        );
                      })}
                  </div>
                </div>
              ))}
          </div>
        ) : (
          <div className="text-center py-12 text-gray-500">No curriculum available yet</div>
        )}
      </div>

      {/* Reviews */}
      <div className="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
        <CourseReviewSection
          courseId={course.id}
          enrolled={enrolled}
          currentUserId={user?.id}
        />
      </div>
    </div>
  );
}
</file>

