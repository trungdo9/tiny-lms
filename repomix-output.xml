                  .sort((a, b) => a.orderIndex - b.orderIndex)
        .map((section, idx) => (
          <SectionCard
                      key= { section.id }
                      section = { section }
                      index = { idx }
                      courseId = { courseId }
                      isExpanded = { expandedSections.has(section.id) }
